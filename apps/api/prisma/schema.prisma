// v2 data model — see docs/system-design_v2.md §4.1 for the full rationale behind each
// constraint below (natural-key uniqueness on Coin, why mintMark/variety default to ''
// instead of null, why the clone FKs are onDelete: SetNull, why Ownership has no FK to
// UserSet/UserSetCoin at all).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  userSets   UserSet[]
  ownerships Ownership[]
}

model Coin {
  id            String   @id @default(uuid())
  country       String
  denomination  String
  year          Int
  mintMark      String   @default("") // never null — see §4.1 NULL-distinctness note
  variety       String   @default("")
  name          String
  imageUrl      String?
  imageSource   String?
  imageLicense  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  canonicalSetCoins CanonicalSetCoin[]
  userSetCoins      UserSetCoin[]
  ownerships        Ownership[]

  @@unique([country, denomination, year, mintMark, variety])
}

model CanonicalSet {
  id              String  @id @default(uuid())
  name            String
  description     String?
  source          String // "admin" | "seed-template"
  templateVersion String

  coins    CanonicalSetCoin[]
  userSets UserSet[]          @relation("ClonedFromCanonical")
}

model CanonicalSetCoin {
  id             String @id @default(uuid())
  canonicalSetId String
  coinId         String
  position       Int

  canonicalSet CanonicalSet @relation(fields: [canonicalSetId], references: [id], onDelete: Cascade)
  coin         Coin         @relation(fields: [coinId], references: [id])

  @@unique([canonicalSetId, coinId])
}

model UserSet {
  id                    String   @id @default(uuid())
  userId                String
  name                  String
  clonedFromCanonicalId String?
  clonedFromUserSetId   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                User          @relation(fields: [userId], references: [id])
  clonedFromCanonical CanonicalSet? @relation("ClonedFromCanonical", fields: [clonedFromCanonicalId], references: [id], onDelete: SetNull)
  clonedFromUserSet   UserSet?      @relation("ClonedFromUserSet", fields: [clonedFromUserSetId], references: [id], onDelete: SetNull)
  clones              UserSet[]     @relation("ClonedFromUserSet")

  coins UserSetCoin[]
}

model UserSetCoin {
  id        String @id @default(uuid())
  userSetId String
  coinId    String
  position  Int

  userSet UserSet @relation(fields: [userSetId], references: [id], onDelete: Cascade)
  coin    Coin    @relation(fields: [coinId], references: [id])

  @@unique([userSetId, coinId])
}

model Ownership {
  userId  String
  coinId  String
  ownedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  coin Coin @relation(fields: [coinId], references: [id])

  @@id([userId, coinId])
}
