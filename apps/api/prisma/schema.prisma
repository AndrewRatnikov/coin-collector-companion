// v2 data model pending — see docs/system-design_v2.md §4.1 for the target shape
// (coins, canonical_sets, canonical_set_coins, user_sets, user_set_coins, ownership).
// The v1 models (User, CollectionSet, SetSlot, UserSet, CoinItem) were removed from this
// file as part of the v2 prep pass, but prisma/migrations/ still holds the migration that
// created them against the real Neon DB — don't hand-edit or delete that history. The next
// `prisma migrate dev` (docs/backlog_week1.md Day 2) will diff this file against that
// history and generate one migration that drops the v1 tables and creates the v2 ones.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
